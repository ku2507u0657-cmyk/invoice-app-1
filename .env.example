# Flask Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
FLASK_ENV=development

# Database
# For local development (SQLite - auto-used if DATABASE_URL not set)
# DATABASE_URL=sqlite:///invoice_app.db
# For production (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/invoice_db

# Email Configuration (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Company Details
COMPANY_NAME=My Coaching Classes
COMPANY_ADDRESS=123 Main Street, Mumbai, Maharashtra 400001
COMPANY_PHONE=+91 98765 43210
COMPANY_EMAIL=info@mycoachingclasses.com
COMPANY_GSTIN=27AABCU9603R1ZX
UPI_ID=mycoaching@upi

# Admin Credentials (for first-time setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123

# App URL (for email links)
APP_URL=http://localhost:5000
